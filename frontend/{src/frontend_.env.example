# CAMResearcher Frontend Environment Variables
# Copy this file to .env and fill in your values

# ===== API CONFIGURATION =====
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=30000  # 30 seconds

# ===== APPLICATION ENVIRONMENT =====
REACT_APP_ENVIRONMENT=development
REACT_APP_VERSION=1.0.0

# ===== APP INFORMATION =====
REACT_APP_NAME=CAMResearcher
REACT_APP_DESCRIPTION=Cambodian Research Registry Platform
REACT_APP_SITE_URL=http://localhost:3000

# ===== LANGUAGE SETTINGS =====
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_FALLBACK_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,km

# ===== GOOGLE ANALYTICS (optional) =====
# REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===== SENTRY (Error Tracking, optional) =====
# REACT_APP_SENTRY_DSN=https://key@sentry.io/project-id

# ===== GOOGLE SCHOLAR INTEGRATION =====
# REACT_APP_GOOGLE_SCHOLAR_URL=https://scholar.google.com

# ===== ORCID INTEGRATION =====
# REACT_APP_ORCID_CLIENT_ID=your_orcid_client_id
# REACT_APP_ORCID_REDIRECT_URI=http://localhost:3000/auth/orcid/callback

# ===== FEATURE FLAGS =====
REACT_APP_ENABLE_SOCIAL_LOGIN=false
REACT_APP_ENABLE_PUBLICATION_IMPORT=true
REACT_APP_ENABLE_PROFILE_VERIFICATION=true
REACT_APP_ENABLE_GRANT_APPLICATIONS=true
REACT_APP_ENABLE_ADMIN_PANEL=true
REACT_APP_ENABLE_EXPORT_PDF=true

# ===== THEME CONFIGURATION =====
REACT_APP_DEFAULT_THEME=light
REACT_APP_PRIMARY_COLOR=#1e40af
REACT_APP_SECONDARY_COLOR=#7c3aed

# ===== FILE UPLOAD =====
REACT_APP_MAX_FILE_SIZE=5242880  # 5MB
REACT_APP_ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png

# ===== PAGINATION =====
REACT_APP_ITEMS_PER_PAGE=10
REACT_APP_MAX_ITEMS_PER_PAGE=100

# ===== EMAIL CONFIGURATION =====
REACT_APP_SUPPORT_EMAIL=support@camresearcher.org
REACT_APP_ADMIN_EMAIL=admin@camresearcher.org

# ===== SECURITY =====
REACT_APP_TOKEN_STORAGE=localStorage  # or sessionStorage
REACT_APP_AUTO_LOGOUT_TIMEOUT=86400000  # 24 hours in milliseconds

# ===== PROXY (for development, if needed) =====
# PROXY=http://localhost:5000

# ===== PUBLIC URL (for deployment) =====
PUBLIC_URL=/

# ===== DEVELOPMENT SERVER =====
# PORT=3000
# BROWSER=none  # Uncomment to prevent auto-opening browser

# ===== BUILD CONFIGURATION =====
# REACT_APP_BUILD_PATH=build
# REACT_APP_SKIP_PREFLIGHT_CHECK=false

# ===== NOTIFICATIONS =====
REACT_APP_ENABLE_TOAST_NOTIFICATIONS=true
REACT_APP_NOTIFICATION_TIMEOUT=5000  # 5 seconds

# ===== SOCIAL MEDIA LINKS =====
REACT_APP_FACEBOOK_URL=https://facebook.com/camresearcher
REACT_APP_TWITTER_URL=https://twitter.com/camresearcher
REACT_APP_LINKEDIN_URL=https://linkedin.com/company/camresearcher
REACT_APP_GITHUB_URL=https://github.com/camresearcher

# ===== EXTERNAL LINKS =====
REACT_APP_MINISTRY_EDUCATION_URL=https://www.moeys.gov.kh/
REACT_APP_DOCUMENTATION_URL=https://docs.camresearcher.org/
REACT_APP_CONTACT_URL=https://camresearcher.org/contact

# ===== MAP INTEGRATION (if using maps) =====
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ===== CUSTOM CONFIGURATION =====
# Add any custom configuration variables here
REACT_APP_INSTITUTION_TYPES=University,Research Institute,Government Agency,NGO,Private Sector
REACT_APP_RESEARCH_FIELDS=Education,Science,Technology,Medicine,Social Science,Arts,Other

# ===== DEBUG MODE =====
# Set to true for development, false for production
REACT_APP_DEBUG=true
