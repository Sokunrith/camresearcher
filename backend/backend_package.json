    "jsonwebtoken": "^9.1.2",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0",
    "nodemailer": "^6.9.7",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "pdfkit": "^0.13.0",
